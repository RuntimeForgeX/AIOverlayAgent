# Local: postgresql://postgres:postgres@localhost:5432/overlay_license?schema=public
# Hosted Postgres: usually add sslmode=require.
# If your provider uses a self-signed cert, add sslaccept=accept_invalid_certs.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/overlay_license?schema=public"
SESSION_SECRET="change-me-in-production-use-long-random-string"
# Local: paths relative to project root (keys/private.pem)
PRIVATE_KEY_PATH="keys/private.pem"
PUBLIC_KEY_PATH="keys/public.pem"
# Vercel / production: paste PEM contents (use \n for newlines in one line)
# PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PORT=3000
NODE_ENV=development
JWT_ISSUER="overlay-agent.local"
APP_BASE_URL="http://localhost:3000"
# Set to 1 to use in-memory sessions (no Postgres session table)
USE_MEMORY_SESSION=0

# Seed admin (prisma/seed.js)
SEED_ADMIN_EMAIL="admin@localhost"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"
