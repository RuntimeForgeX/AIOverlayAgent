<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %> · AI Overlay License</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/nav') %>
    <main class="app-main">
      <div class="auth-wrap">
        <section class="auth-hero">
          <div>
            <span class="hero-kicker mb-4">Premium access</span>
            <h1 class="mb-3">Request access to AI Overlay licensing.</h1>
            <p class="lead mb-0">Create your account, submit a license request, and receive an activation key after admin approval.</p>
          </div>
          <div class="row g-3 position-relative">
            <div class="col-sm-6">
              <div class="auth-feature">
                <span>1</span>
                <span>Create account</span>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="auth-feature">
                <span>2</span>
                <span>Request license</span>
              </div>
            </div>
          </div>
        </section>

        <section class="card-app auth-card">
          <div class="mb-4">
            <h1 class="mb-2">Create account</h1>
            <p class="page-subtitle mb-0">Register to request and track your license.</p>
          </div>
          <% if (error) { %><div class="alert alert-app alert-danger-app mb-3"><%= error %></div><% } %>
          <form method="post" action="/register">
            <div class="mb-3">
              <label class="form-label" for="name">Full name</label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Your name" autocomplete="name" />
            </div>
            <div class="mb-3">
              <label class="form-label" for="email">Email address</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required autocomplete="email" />
            </div>
            <div class="mb-4">
              <label class="form-label" for="password">Password</label>
              <input type="password" id="password" name="password" class="form-control" placeholder="At least 8 characters" minlength="8" required autocomplete="new-password" />
              <div class="form-text small mt-2">Use at least 8 characters for your account password.</div>
            </div>
            <button type="submit" class="btn btn-accent w-100 py-2">Create account</button>
          </form>
          <p class="mt-4 mb-0 text-center page-subtitle small">
            Already registered? <a href="/login">Sign in</a>
          </p>
        </section>
      </div>
    </main>
    <%- include('partials/footer') %>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
