<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %> · AI Overlay License</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/nav') %>
    <main class="app-main admin-wrap">
      <%- include('partials/flash') %>
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
          <span class="hero-kicker mb-3" style="background: var(--primary-soft); color: var(--primary);">License registry</span>
          <h1 class="page-title display-6 mb-2">All licenses</h1>
          <p class="page-subtitle mb-0">Manage revocations, device bindings, and license metadata.</p>
        </div>
        <a href="/admin" class="btn btn-ghost px-4">← Admin dashboard</a>
      </div>

      <div class="card-app">
        <div class="card-header-app">
          <div>
            <p class="section-title">License inventory</p>
            <p class="section-meta"><%= licenses.length %> issued license(s)</p>
          </div>
        </div>
        <div class="card-body-app p-0">
          <% if (!licenses.length) { %>
            <div class="empty-state py-5">
              <div class="empty-state-icon">◇</div>
              <p class="mb-0">No licenses issued yet.</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-app mb-0">
                <thead>
                  <tr>
                    <th>User</th>
                    <th>Plan</th>
                    <th>JTI</th>
                    <th>Expires</th>
                    <th>Devices</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% licenses.forEach(function(lic) { %>
                    <tr>
                      <td>
                        <div class="fw-semibold"><%= lic.user.email %></div>
                        <% if (lic.user.name) { %><div class="section-meta"><%= lic.user.name %></div><% } %>
                      </td>
                      <td class="text-capitalize fw-semibold"><%= lic.plan %></td>
                      <td><code><%= lic.jti.slice(0, 8) %>…</code></td>
                      <td class="page-subtitle small"><%= lic.expiresAt ? formatDate(lic.expiresAt) : 'Lifetime' %></td>
                      <td>
                        <% lic.devices.forEach(function(d) { %>
                          <div class="small mb-1 d-flex align-items-center gap-2 flex-wrap">
                            <code><%= d.deviceHash.slice(0, 12) %>…</code>
                            <form action="/admin/devices/<%= d.id %>/unbind" method="post" class="d-inline">
                              <button type="submit" class="btn btn-sm btn-link p-0">Unbind</button>
                            </form>
                          </div>
                        <% }); %>
                        <% if (!lic.devices.length) { %><span class="page-subtitle">—</span><% } %>
                      </td>
                      <td>
                        <% if (lic.revoked) { %>
                          <span class="badge-status badge-revoked">Revoked</span>
                        <% } else { %>
                          <span class="badge-status badge-active">Active</span>
                        <% } %>
                      </td>
                      <td class="text-end">
                        <% if (!lic.revoked) { %>
                          <form action="/admin/licenses/<%= lic.id %>/revoke" method="post" class="d-inline" onsubmit="return confirm('Revoke this license?');">
                            <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);">Revoke</button>
                          </form>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
