<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %> · AI Overlay License</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/nav') %>
    <main class="app-main admin-wrap">
      <%- include('partials/flash') %>
      <div class="hero-panel mb-4">
        <span class="hero-kicker mb-3">Admin console</span>
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 position-relative">
          <div>
            <h1 class="page-title display-6 mb-2">License operations dashboard</h1>
            <p class="page-subtitle mb-0">Review requests, issue signed keys, and manage active device bindings.</p>
          </div>
          <a href="/admin/licenses" class="btn btn-light fw-bold px-4">View licenses</a>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="stat-card">
            <div class="stat-label">Users</div>
            <div class="stat-value"><%= stats.users %></div>
            <p class="section-meta mb-0">Registered accounts</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card">
            <div class="stat-label">Active licenses</div>
            <div class="stat-value"><%= stats.activeLicenses %></div>
            <p class="section-meta mb-0">Currently not revoked</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card stat-warning">
            <div class="stat-label">Pending requests</div>
            <div class="stat-value"><%= stats.pendingRequests %></div>
            <p class="section-meta mb-0">Waiting for approval</p>
          </div>
        </div>
      </div>

      <% if (lastIssuedJwt) { %>
        <div class="card-app highlight-card mb-4">
          <div class="card-header-app">
            <div>
              <p class="section-title">Last issued raw JWT</p>
              <p class="section-meta">Copy this key for the requesting user.</p>
            </div>
            <button type="button" class="btn btn-sm btn-accent" data-copy-target="#last-issued-jwt">Copy JWT</button>
          </div>
          <div class="card-body-app">
            <div class="jwt-box" id="last-issued-jwt"><%= lastIssuedJwt %></div>
          </div>
        </div>
      <% } %>

      <div class="card-app mb-4">
        <div class="card-header-app">
          <div>
            <p class="section-title">Pending requests</p>
            <p class="section-meta">Approve to issue a signed raw license key.</p>
          </div>
          <% if (pending.length) { %><span class="badge-status badge-pending"><%= pending.length %> open</span><% } %>
        </div>
        <div class="card-body-app p-0">
          <% if (!pending.length) { %>
            <div class="empty-state py-5">
              <div class="empty-state-icon">✓</div>
              <p class="mb-0">No pending requests. The queue is clean.</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-app mb-0">
                <thead>
                  <tr><th>User</th><th>Plan</th><th>Notes</th><th>Date</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                  <% pending.forEach(function(r) { %>
                    <tr>
                      <td>
                        <div class="fw-semibold"><%= r.user.email %></div>
                        <% if (r.user.name) { %><div class="section-meta"><%= r.user.name %></div><% } %>
                      </td>
                      <td class="text-capitalize fw-semibold"><%= r.plan %></td>
                      <td class="page-subtitle small"><%= r.notes || '—' %></td>
                      <td class="page-subtitle small"><%= formatDate(r.createdAt) %></td>
                      <td class="text-end text-nowrap">
                        <form action="/admin/requests/<%= r.id %>/approve" method="post" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-accent">Approve</button>
                        </form>
                        <form action="/admin/requests/<%= r.id %>/reject" method="post" class="d-inline ms-1">
                          <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);">Reject</button>
                        </form>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <div class="card-app">
        <div class="card-header-app">
          <div>
            <p class="section-title">Recent licenses</p>
            <p class="section-meta">Latest issued licenses and status.</p>
          </div>
          <a href="/admin/licenses" class="btn btn-sm btn-ghost">View all</a>
        </div>
        <div class="card-body-app p-0">
          <div class="table-responsive">
            <table class="table table-app table-sm mb-0">
              <thead>
                <tr><th>User</th><th>Plan</th><th>Devices</th><th>Status</th><th class="text-end">Actions</th></tr>
              </thead>
              <tbody>
                <% licenses.forEach(function(lic) { %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= lic.user.email %></div>
                      <% if (lic.user.name) { %><div class="section-meta"><%= lic.user.name %></div><% } %>
                    </td>
                    <td class="text-capitalize fw-semibold"><%= lic.plan %></td>
                    <td><span class="badge-status badge-approved"><%= lic.devices.length %></span></td>
                    <td>
                      <% if (lic.revoked) { %>
                        <span class="badge-status badge-revoked">Revoked</span>
                      <% } else { %>
                        <span class="badge-status badge-active">Active</span>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <% if (!lic.revoked) { %>
                        <form action="/admin/licenses/<%= lic.id %>/revoke" method="post" class="d-inline" onsubmit="return confirm('Revoke this license?');">
                          <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);">Revoke</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
