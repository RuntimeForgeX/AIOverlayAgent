<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %> · AI Overlay License</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container-fluid px-4">
    <%- include('partials/flash') %>
    <h1 class="h3 mb-4">Admin dashboard</h1>

    <div class="row g-3 mb-4">
      <div class="col-md-4"><div class="card p-3"><div class="text-secondary small">Users</div><div class="h3"><%= stats.users %></div></div></div>
      <div class="col-md-4"><div class="card p-3"><div class="text-secondary small">Active licenses</div><div class="h3"><%= stats.activeLicenses %></div></div></div>
      <div class="col-md-4"><div class="card p-3"><div class="text-secondary small">Pending requests</div><div class="h3 text-warning"><%= stats.pendingRequests %></div></div></div>
    </div>

    <% if (lastIssuedJwt) { %>
      <div class="card p-4 mb-4 border-success">
        <h2 class="h5 text-success">Last issued raw JWT (copy to user)</h2>
        <div class="jwt-box"><%= lastIssuedJwt %></div>
        <p class="small text-secondary mt-2 mb-0">User pastes this in the Python overlay app, then clicks Activate.</p>
      </div>
    <% } %>

    <div class="card p-4 mb-4">
      <h2 class="h5">Pending requests</h2>
      <% if (!pending.length) { %>
        <p class="text-secondary mb-0">No pending requests.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr><th>User</th><th>Plan</th><th>Notes</th><th>Date</th><th></th></tr>
          </thead>
          <tbody>
            <% pending.forEach(function(r) { %>
              <tr>
                <td><%= r.user.email %></td>
                <td><%= r.plan %></td>
                <td><%= r.notes || '—' %></td>
                <td><%= formatDate(r.createdAt) %></td>
                <td class="text-nowrap">
                  <form action="/admin/requests/<%= r.id %>/approve" method="post" class="d-inline">
                    <button class="btn btn-sm btn-accent">Approve</button>
                  </form>
                  <form action="/admin/requests/<%= r.id %>/reject" method="post" class="d-inline">
                    <button class="btn btn-sm btn-outline-danger">Reject</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="card p-4">
      <h2 class="h5">Recent licenses</h2>
      <a href="/admin/licenses" class="btn btn-sm btn-outline-light mb-3">View all</a>
      <table class="table table-sm">
        <thead>
          <tr><th>User</th><th>Plan</th><th>Devices</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          <% licenses.forEach(function(lic) { %>
            <tr>
              <td><%= lic.user.email %></td>
              <td><%= lic.plan %></td>
              <td><%= lic.devices.length %></td>
              <td><%= lic.revoked ? 'Revoked' : 'OK' %></td>
              <td>
                <% if (!lic.revoked) { %>
                  <form action="/admin/licenses/<%= lic.id %>/revoke" method="post" class="d-inline" onsubmit="return confirm('Revoke this license?');">
                    <button class="btn btn-sm btn-outline-danger">Revoke</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
