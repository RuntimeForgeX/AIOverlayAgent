<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %> · AI Overlay License</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/nav') %>
    <main class="app-main">
      <div class="auth-wrap">
        <section class="auth-hero">
          <div>
            <span class="hero-kicker mb-4">License control plane</span>
            <h1 class="mb-3">Manage premium activations with confidence.</h1>
            <p class="lead mb-0">Issue, activate, and audit AI Overlay licenses from a clean operations dashboard built for real users.</p>
          </div>
          <div class="row g-3 position-relative">
            <div class="col-sm-6">
              <div class="auth-feature">
                <span>✓</span>
                <span>RSA-signed license keys</span>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="auth-feature">
                <span>↯</span>
                <span>Device-bound activations</span>
              </div>
            </div>
          </div>
        </section>

        <section class="card-app auth-card">
          <div class="mb-4">
            <h1 class="mb-2">Welcome back</h1>
            <p class="page-subtitle mb-0">Sign in to review requests and manage licenses.</p>
          </div>
          <% if (error) { %><div class="alert alert-app alert-danger-app mb-3"><%= error %></div><% } %>
          <form method="post" action="/login">
            <div class="mb-3">
              <label class="form-label" for="email">Email address</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required autocomplete="email" />
            </div>
            <div class="mb-4">
              <label class="form-label" for="password">Password</label>
              <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-accent w-100 py-2">Sign in</button>
          </form>
          <p class="mt-4 mb-0 text-center page-subtitle small">
            Need a license? <a href="/register">Create an account</a>
          </p>
        </section>
      </div>
    </main>
    <%- include('partials/footer') %>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
