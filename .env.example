# OpenRouter (recommended — one key for Gemini, Claude, GPT, etc.)
OPENROUTER_API_KEY=sk-or-your-key-here

# Direct provider keys (only if using "direct" models in the dropdown)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Direct OpenAI (GPT-5.2, GPT-4o, o3 — dropdown entries marked "direct")
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
