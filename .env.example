# =============================================================================
# Local development (.env) — copy to project root as `.env`
#   copy .env.example .env
# Windows system env vars always win over .env (see load_environment).
# =============================================================================

# --- API keys (runtime secrets — never bundled into the exe) ---
# These are the ONLY values that belong in .env.
# All LICENSE_* settings are build-time constants in config.ini [LICENSE].

OPENROUTER_API_KEY=sk-or-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
