# =============================================================================
# Local development (.env) — copy to project root as `.env`
#   copy .env.example .env
# Windows system env vars always win over .env (see load_environment).
# =============================================================================

# --- Premium license (Node.js on localhost) ---
# 0 = skip license gate (dev)   |   1 = require valid license (test prod flow)
LICENSE_AUTH=0
# Optional legacy alias: 1 also skips the gate
# OVERLAY_LICENSE_BYPASS=1

# Node server port (used when URLs below are not set)
LICENSE_NODE_PORT=3000
LICENSE_ACTIVATE_BASE_URL=http://localhost:3000
LICENSE_GET_LICENSE_URL=http://localhost:3000/request
LICENSE_ACTIVATE_PATH=/api/activate

# --- API keys ---
OPENROUTER_API_KEY=sk-or-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
